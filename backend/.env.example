# backend/.env.example
# ============================================================
# ENVIRONMENT
# ============================================================
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# ============================================================
# SERVER
# ============================================================
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=False

# ============================================================
# COOKIE SETTINGS (for frontend authentication)
# ============================================================
COOKIE_NAME=beubble_session
COOKIE_MAX_AGE=86400
COOKIE_HTTPONLY=True
COOKIE_SECURE=True
COOKIE_SAMESITE=lax

# ============================================================
# API KEYS - BEUBBLE
# ============================================================
API_KEY=your_beubble_super_secret_key_here
API_KEY_HEADER=X-API-Key

# ============================================================
# EXTERNAL SERVICES - YOUR KEYS
# ============================================================

# DASHSCOPE (Aliyun) - For Qwen Models
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# BRAVE SEARCH - For web search capabilities
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# JINA AI - For embeddings and reranking
JINA_API_KEY=your_jina_api_key_here

# ============================================================
# DATABASE
# ============================================================
DATABASE_DIR=./database
WORKSPACE_DIR=./workspace
LOGS_DIR=./logs

# ============================================================
# QDRANT (Vector Database)
# ============================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=beubble_memory

# ============================================================
# MODEL CONFIGURATION
# ============================================================
DEFAULT_MODEL=qwen-plus
EMBEDDING_MODEL=jina-embeddings-v2
MAX_TOKENS=4096
TEMPERATURE=0.7
